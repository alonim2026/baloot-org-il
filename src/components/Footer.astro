---
// src/components/Footer.astro
---

<footer class="site-footer">
  <div class="container footer-grid">

    <!-- עמודה 1 – אודות -->
    <div class="footer-col footer-about">
      <h4>עמותת אלוני ישראל</h4>
      <p>
        העמותה פועלת לטפח, לשמור ולהגן על עצי האלון ברחבי הארץ<br />
        העמותה מקדמת את הכרזתו של האלון –
        <a href="/projects/the-oak-national-tree-of-israel" class="footer-link-highlight">כעץ הלאומי של ישראל</a>
      </p>
      <div class="footer-social">
        <a href="https://www.facebook.com/עמותת-אלוני-ישראל-IOA-Israel-Oak-Association-2376454072399448" target="_blank" rel="noopener" aria-label="פייסבוק">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="https://www.linkedin.com/company/israel-oak-association" target="_blank" rel="noopener" aria-label="לינקדאין">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="https://www.youtube.com/@israeloakassociation" target="_blank" rel="noopener" aria-label="יוטיוב">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="white"/></svg>
        </a>
      </div>
    </div>

    <!-- עמודה 2 – פרטי התקשרות -->
    <div class="footer-col footer-contact">
      <h4>פרטי התקשרות</h4>
      <ul class="contact-list">
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          כתובת: השיטה 5, חרב לאת, 3886000
        </li>
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
          ניד: <a href="tel:0544700025">054-470-0025</a>
        </li>
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13.6 19.79 19.79 0 0 1 1.58 5a2 2 0 0 1 1.95-2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 10.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 17z"/></svg>
          טל׳: <a href="tel:046366248">04-636-6248</a>
        </li>
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:baloot@baloot.org.il">baloot@baloot.org.il</a>
        </li>
        <li>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
          <a href="https://baloot.org.il" target="_blank">baloot.org.il</a>
        </li>
      </ul>
      <div class="footer-links-extra">
        <a href="/members">אזור חברי העמותה</a>
        <a href="/english">יציאה / English</a>
      </div>
    </div>

    <!-- עמודה 3 – טופס יצירת קשר -->
    <div class="footer-col footer-form-col">
      <h4>דברו איתנו</h4>
      <form
        class="footer-form"
        id="footer-contact-form"
        action="https://formspree.io/f/YOUR_FORM_ID"
        method="POST"
      >
        <div class="form-row-2">
          <input type="text"  name="name"  placeholder="*שם מלא"   required />
          <input type="tel"   name="phone" placeholder="טלפון"              />
        </div>
        <input type="email" name="email" placeholder='*דוא"ל' required />
        <textarea name="message" placeholder="הודעה" rows="3"></textarea>
        <button type="submit" class="footer-submit">שלח</button>
        <p class="footer-form-success" id="footer-success">✅ תודה! ההודעה נשלחה.</p>
      </form>
    </div>

  </div>

  <!-- שורה תחתונה -->
  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>© {new Date().getFullYear()} עמותת אלוני ישראל. כל הזכויות שמורות. ע.ר. 58-073-5892-5</span>
      <span>
        <a href="/accessibility">נגישות</a>
        &nbsp;·&nbsp;
        <a href="/privacy">פרטיות</a>
      </span>
    </div>
  </div>
</footer>

<script>
  const form    = document.getElementById('footer-contact-form') as HTMLFormElement;
  const success = document.getElementById('footer-success');
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const res  = await fetch(form.action, {
      method: 'POST', body: data,
      headers: { Accept: 'application/json' }
    });
    if (res.ok) {
      form.reset();
      if (success) success.style.display = 'block';
    }
  });
</script>

<style>
/* ── פוטר – ירוק כהה עם טקסטורה ─────────────────── */
.site-footer {
  background-color: #1e2e1a;
  background-image:
    radial-gradient(ellipse at 20% 50%, rgba(44,63,41,0.6) 0%, transparent 60%),
    radial-gradient(ellipse at 80% 20%, rgba(58,84,54,0.4) 0%, transparent 50%),
    url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  color: rgba(255,255,255,0.78);
  margin-top: 0;
}

.footer-grid {
  display: grid;
  grid-template-columns: 1.6fr 1.4fr 1.6fr;
  gap: var(--space-10);
  padding: var(--space-12) var(--space-6) var(--space-10);
}

/* ── עמודות ─────────────────────────────────────── */
.footer-col h4 {
  color: #8bc34a;
  font-family: var(--ff-body);
  font-size: var(--fs-sm);
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: var(--space-4);
  border-bottom: 1px solid rgba(139,195,74,0.25);
  padding-bottom: var(--space-3);
}

.footer-about p {
  font-size: var(--fs-sm);
  line-height: 1.8;
  color: rgba(255,255,255,0.72);
}
.footer-link-highlight {
  color: #8bc34a;
  font-weight: 700;
  text-decoration: underline;
  text-underline-offset: 3px;
}
.footer-link-highlight:hover { color: #aed75f; }

/* סושיאל */
.footer-social {
  display: flex;
  gap: var(--space-3);
  margin-top: var(--space-5);
}
.footer-social a {
  display: flex; align-items: center; justify-content: center;
  width: 36px; height: 36px;
  background: rgba(255,255,255,0.10);
  border-radius: 50%;
  color: rgba(255,255,255,0.80);
  transition: background 0.2s, color 0.2s;
}
.footer-social a:hover {
  background: #3a5436;
  color: white;
}

/* ── פרטי קשר ───────────────────────────────────── */
.contact-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  font-size: var(--fs-sm);
}
.contact-list li {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  color: rgba(255,255,255,0.72);
  line-height: 1.5;
}
.contact-list li svg { flex-shrink: 0; margin-top: 2px; opacity: 0.7; }
.contact-list a { color: #8bc34a; }
.contact-list a:hover { color: #aed75f; }

.footer-links-extra {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  margin-top: var(--space-6);
  padding-top: var(--space-4);
  border-top: 1px solid rgba(255,255,255,0.1);
}
.footer-links-extra a {
  font-size: var(--fs-sm);
  color: rgba(255,255,255,0.55);
  transition: color 0.2s;
}
.footer-links-extra a:hover { color: white; }

/* ── טופס ──────────────────────────────────────── */
.footer-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}
.form-row-2 {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3);
}
.footer-form input,
.footer-form textarea {
  background: rgba(255,255,255,0.08);
  border: 1px solid rgba(255,255,255,0.18);
  border-radius: var(--radius-sm);
  padding: 9px 12px;
  font-size: var(--fs-sm);
  color: white;
  direction: rtl;
  text-align: right;
  transition: border-color 0.2s, background 0.2s;
  resize: none;
}
.footer-form input::placeholder,
.footer-form textarea::placeholder { color: rgba(255,255,255,0.40); }
.footer-form input:focus,
.footer-form textarea:focus {
  outline: none;
  border-color: #8bc34a;
  background: rgba(255,255,255,0.12);
}
.footer-submit {
  background: #3a5436;
  color: white;
  border: none;
  border-radius: var(--radius-sm);
  padding: 10px;
  font-size: var(--fs-sm);
  font-weight: 700;
  cursor: pointer;
  transition: background 0.2s;
  align-self: flex-start;
  min-width: 80px;
}
.footer-submit:hover { background: #4a6e44; }
.footer-form-success {
  display: none;
  font-size: var(--fs-xs);
  color: #8bc34a;
  font-weight: 600;
}

/* ── שורה תחתונה ────────────────────────────────── */
.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.08);
  padding: var(--space-4) 0;
  background: rgba(0,0,0,0.2);
}
.footer-bottom-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: var(--fs-xs);
  color: rgba(255,255,255,0.38);
  flex-wrap: wrap;
  gap: var(--space-3);
}
.footer-bottom a { color: rgba(255,255,255,0.45); }
.footer-bottom a:hover { color: rgba(255,255,255,0.8); }

/* ── Responsive ─────────────────────────────────── */
@media (max-width: 860px) {
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .footer-about { grid-column: 1 / -1; }
}
@media (max-width: 500px) {
  .footer-grid { grid-template-columns: 1fr; }
  .form-row-2 { grid-template-columns: 1fr; }
  .footer-bottom-inner { flex-direction: column; text-align: center; }
}
</style>
