---
// src/pages/events/[slug].astro
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const items = await getCollection('events');
  return items.map(item => ({ params: { slug: item.slug } }));
};

const { slug } = Astro.params;
const items = await getCollection('events');
const item  = items.find(p => p.slug === slug);
if (!item) return Astro.redirect('/events');

const { Content } = await render(item);
const { title, topImage, eventDate, location, link } = item.data;
---

<Base title={title}>

  <header class="article-hero" style={topImage ? `--img: url('${topImage}')` : ''}>
    {topImage && <div class="article-hero-overlay"></div>}
    <div class="container article-hero-inner">
      <a href="/events" class="back-link">← לוח אירועים</a>
      <h1>{title}</h1>
      {(eventDate || location) && (
        <p class="event-meta">
          {eventDate && <span>📅 {eventDate}</span>}
          {location  && <span>📍 {location}</span>}
        </p>
      )}
    </div>
  </header>

  <article class="section">
    <div class="container prose">
      <Content />
      {link && (
        <div style="margin-top: var(--space-8)">
          <a href={link.url} class="btn btn-primary" target="_blank" rel="noopener">
            {link.title ?? 'הרשמה'}
          </a>
        </div>
      )}
    </div>
  </article>

  <div class="container" style="padding-bottom: var(--space-16)">
    <a href="/events" class="btn btn-outline">← כל האירועים</a>
  </div>

</Base>

<style>
.article-hero {
  background: var(--img, var(--clr-oak-800)) center/cover no-repeat;
  min-height: 320px; display: flex; align-items: flex-end; position: relative;
}
.article-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(5,20,2,0.88), rgba(5,20,2,0.3)); }
.article-hero-inner { position: relative; z-index: 1; padding-bottom: var(--space-12); display: flex; flex-direction: column; gap: var(--space-4); }
.article-hero-inner h1 { color: white; max-width: 820px; }
.back-link { color: rgba(255,255,255,0.70); font-size: var(--fs-sm); font-weight: 600; }
.back-link:hover { color: white; }
.event-meta { color: rgba(255,255,255,0.80); font-size: var(--fs-sm); display: flex; gap: var(--space-6); }
</style>
