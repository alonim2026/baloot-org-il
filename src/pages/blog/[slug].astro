---
// src/pages/blog/[slug].astro
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map(post => ({ params: { slug: post.slug } }));
};

const { slug } = Astro.params;
const posts = await getCollection('blog');
const post  = posts.find(p => p.slug === slug);

if (!post) return Astro.redirect('/blog');

const { Content } = await render(post);
const { title, date, topImage, author, excerpt } = post.data;

function fmt(d: Date | string) {
  return new Date(d).toLocaleDateString('he-IL', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title={title} description={excerpt ?? title} image={topImage}>

  <!-- Article hero -->
  <header class="article-hero" style={topImage ? `--img: url('${topImage}')` : ''}>
    {topImage && <div class="article-hero-overlay"></div>}
    <div class="container article-hero-inner">
      <a href="/blog" class="back-link">← חזרה לבלוג</a>
      <h1>{title}</h1>
      <p class="article-meta">
        {fmt(date)}
        {author && <span> · {author}</span>}
      </p>
    </div>
  </header>

  <!-- Article body -->
  <article class="section">
    <div class="container prose">
      <Content />
    </div>
  </article>

  <!-- Back link -->
  <div class="container" style="padding-bottom: var(--space-16)">
    <a href="/blog" class="btn btn-outline">← חזרה לבלוג</a>
  </div>

</Base>

<style>
.article-hero {
  background: var(--img, var(--clr-oak-900)) center/cover no-repeat;
  min-height: 380px;
  display: flex;
  align-items: flex-end;
  position: relative;
}
.article-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(5,20,2,0.88), rgba(5,20,2,0.30));
}
.article-hero-inner {
  position: relative; z-index: 1;
  padding-bottom: var(--space-12);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}
.article-hero-inner h1 { color: white; max-width: 820px; }
.article-meta { color: rgba(255,255,255,0.75); font-size: var(--fs-sm); font-weight: 500; }
.back-link { color: rgba(255,255,255,0.70); font-size: var(--fs-sm); font-weight: 600; }
.back-link:hover { color: white; }
</style>
