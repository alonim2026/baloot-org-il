---
// src/pages/contact.astro
import Base from '../layouts/Base.astro';
---

<Base title="צור קשר" description="צרו קשר עם עמותת אלוני ישראל">

  <section class="page-hero">
    <div class="container">
      <span class="tag">נשמח לשמוע</span>
      <h1>צור קשר</h1>
      <p class="hero-sub">שאלות, הצעות, שיתופי פעולה — כתבו לנו</p>
    </div>
  </section>

  <section class="section">
    <div class="container contact-grid">

      <div class="contact-info">
        <h2>דרכי יצירת קשר</h2>
        <div class="info-list">
          <div class="info-item">
            <span class="info-icon">✉️</span>
            <div>
              <strong>דוא"ל</strong>
              <a href="mailto:baloot@baloot.org.il">baloot@baloot.org.il</a>
            </div>
          </div>
          <div class="info-item">
            <span class="info-icon">🌐</span>
            <div>
              <strong>אתר</strong>
              <a href="https://baloot.org.il" target="_blank">baloot.org.il</a>
            </div>
          </div>
          <div class="info-item">
            <span class="info-icon">📘</span>
            <div>
              <strong>פייסבוק</strong>
              <a href="https://www.facebook.com/עמותת-אלוני-ישראל" target="_blank" rel="noopener">
                עמותת אלוני ישראל
              </a>
            </div>
          </div>
          <div class="info-item">
            <span class="info-icon">🌳</span>
            <div>
              <strong>מפת האלונים (מ.א.י)</strong>
              <a href="https://ior.maps.arcgis.com/apps/webappviewer/index.html?id=f1c7aa1642f042b3b83edc8d6cc15241" target="_blank" rel="noopener">
                פתח מפה
              </a>
            </div>
          </div>
        </div>

        <div class="join-box">
          <h3>הצטרפות לעמותה</h3>
          <p>כל הפעילות של העמותה היא בהתנדבות מלאה. אנו מזמינים אתכם להצטרף ולפעול יחד.</p>
          <a href="/join" class="btn btn-primary">להצטרפות ולתרומה</a>
        </div>
      </div>

      <!-- Contact form – using Formspree (no server) -->
      <!-- החליפו YOUR_FORM_ID במזהה מ-formspree.io -->
      <div class="contact-form-wrap">
        <h2>שלחו הודעה</h2>
        <form
          class="contact-form"
          action="https://formspree.io/f/YOUR_FORM_ID"
          method="POST"
          id="contact-form"
        >
          <div class="form-row">
            <label for="name">שם מלא *</label>
            <input type="text" id="name" name="name" required placeholder="ישראל ישראלי" />
          </div>
          <div class="form-row">
            <label for="email">דוא"ל *</label>
            <input type="email" id="email" name="email" required placeholder="israel@example.com" />
          </div>
          <div class="form-row">
            <label for="subject">נושא</label>
            <input type="text" id="subject" name="subject" placeholder="נושא ההודעה" />
          </div>
          <div class="form-row">
            <label for="message">הודעה *</label>
            <textarea id="message" name="message" rows="6" required placeholder="כתבו את הודעתכם כאן..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary submit-btn">שלח הודעה →</button>
          <p class="form-note" id="form-success" style="display:none">✅ תודה! הודעתך נשלחה בהצלחה.</p>
        </form>
      </div>

    </div>
  </section>

</Base>

<script>
  // Handle Formspree AJAX submit
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
    if (res.ok) {
      form.reset();
      if (success) success.style.display = 'block';
    }
  });
</script>

<style>
.page-hero {
  background: linear-gradient(135deg, var(--clr-oak-900), var(--clr-oak-700));
  color: white; padding: var(--space-16) 0 var(--space-12);
}
.page-hero h1 { color: white; margin: var(--space-4) 0 var(--space-3); }
.hero-sub { font-size: var(--fs-lg); opacity: 0.8; }

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: var(--space-12);
  align-items: start;
}

.contact-info h2 { margin-bottom: var(--space-8); }
.info-list { display: flex; flex-direction: column; gap: var(--space-6); margin-bottom: var(--space-10); }
.info-item { display: flex; gap: var(--space-4); align-items: flex-start; }
.info-icon { font-size: 1.4rem; flex-shrink: 0; }
.info-item strong { display: block; font-size: var(--fs-sm); color: var(--clr-muted); margin-bottom: 2px; }
.info-item a { font-weight: 500; }

.join-box {
  background: var(--clr-oak-50);
  border: 1px solid rgba(61,114,39,0.2);
  border-radius: var(--radius-lg);
  padding: var(--space-8);
  display: flex; flex-direction: column; gap: var(--space-4);
}
.join-box h3 { color: var(--clr-oak-800); }
.join-box p { font-size: var(--fs-sm); color: var(--clr-muted); }

.contact-form-wrap {
  background: var(--clr-surface);
  border: 1px solid var(--clr-border);
  border-radius: var(--radius-xl);
  padding: var(--space-10);
  box-shadow: var(--shadow-md);
}
.contact-form-wrap h2 { margin-bottom: var(--space-8); }

.contact-form { display: flex; flex-direction: column; gap: var(--space-6); }
.form-row { display: flex; flex-direction: column; gap: var(--space-2); }
.form-row label { font-size: var(--fs-sm); font-weight: 600; color: var(--clr-text); }

.form-row input,
.form-row textarea {
  border: 1.5px solid var(--clr-border);
  border-radius: var(--radius-md);
  padding: 10px 14px;
  font-size: var(--fs-md);
  color: var(--clr-text);
  background: var(--clr-bg);
  transition: border-color var(--transition);
  resize: vertical;
  direction: rtl;
  text-align: right;
}
.form-row input:focus,
.form-row textarea:focus {
  outline: none;
  border-color: var(--clr-oak-600);
  background: white;
}

.submit-btn { align-self: flex-start; }
.form-note { font-size: var(--fs-sm); color: var(--clr-oak-700); font-weight: 500; }

@media (max-width: 860px) {
  .contact-grid { grid-template-columns: 1fr; }
}
</style>
