---
// src/pages/guides/[slug].astro
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const items = await getCollection('guides');
  return items.map(item => ({ params: { slug: item.slug } }));
};

const { slug } = Astro.params;
const items = await getCollection('guides');
const item  = items.find(p => p.slug === slug);
if (!item) return Astro.redirect('/guides');

const { Content } = await render(item);
const { title, topImage, excerpt } = item.data;
---

<Base title={title} description={excerpt ?? title} image={topImage}>

  <header class="article-hero" style={topImage ? `--img: url('${topImage}')` : ''}>
    {topImage && <div class="article-hero-overlay"></div>}
    <div class="container article-hero-inner">
      <a href="/guides" class="back-link">← מדריכים</a>
      <h1>{title}</h1>
    </div>
  </header>

  <article class="section">
    <div class="container prose">
      <Content />
    </div>
  </article>

  <div class="container" style="padding-bottom: var(--space-16)">
    <a href="/guides" class="btn btn-outline">← כל המדריכים</a>
  </div>

</Base>

<style>
.article-hero {
  background: var(--img, var(--clr-oak-800)) center/cover no-repeat;
  min-height: 300px; display: flex; align-items: flex-end; position: relative;
}
.article-hero-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to top, rgba(5,20,2,0.85), rgba(5,20,2,0.25));
}
.article-hero-inner {
  position: relative; z-index: 1;
  padding-bottom: var(--space-12);
  display: flex; flex-direction: column; gap: var(--space-4);
}
.article-hero-inner h1 { color: white; max-width: 820px; }
.back-link { color: rgba(255,255,255,0.70); font-size: var(--fs-sm); font-weight: 600; }
.back-link:hover { color: white; }
</style>
